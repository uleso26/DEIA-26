  "edges": [
    {
      "source": "drug:metformin",
      "target": "class:sglt2_inhibitor",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "CKD stage 3"
      ],
      "guideline_id": "guideline:nice_ng28_2026",
      "rationale": "Prioritize renal and cardiovascular protection when renal function permits."
    },
    {
      "source": "drug:metformin",
      "target": "class:glp1_agonist",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "obesity",
        "need_weight_loss"
      ],
      "guideline_id": "guideline:ada_2025",
      "rationale": "Consider GLP-1 receptor agonists when additional weight loss or cardiorenal benefit is desired."
    },
    {
      "source": "drug:metformin",
      "target": "class:dual_incretin",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "obesity",
        "need_weight_loss"
      ],
      "guideline_id": "guideline:ada_2025",
      "rationale": "Dual GIP/GLP-1 incretin therapy is relevant when obesity and weight-loss priority dominate treatment selection."
    },
    {
      "source": "drug:metformin",
      "target": "class:sglt2_inhibitor",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "heart failure"
      ],
      "guideline_id": "guideline:ada_2025",
      "rationale": "Prioritize SGLT2 inhibitors when heart-failure risk reduction is a dominant treatment objective."
    },
    {
      "source": "drug:metformin",
      "target": "class:glp1_agonist",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "ASCVD",
        "need_weight_loss"
      ],
      "guideline_id": "guideline:ada_2025",
      "rationale": "Consider GLP-1 receptor agonists when atherosclerotic cardiovascular risk and weight-loss goals are both relevant."
    },
    {
      "source": "drug:metformin",
      "target": "class:dpp4_inhibitor",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "avoid_hypoglycemia"
      ],
      "guideline_id": "guideline:nice_ng28_2026",
      "rationale": "DPP-4 inhibitors remain useful low-hypoglycemia oral add-on options when cardiorenal priorities are not dominant."
    },
    {
      "source": "drug:metformin",
      "target": "class:sulfonylurea",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "cost_sensitive"
      ],
      "guideline_id": "guideline:nice_ng28_2026",
      "rationale": "Sulfonylureas remain lower-cost options, while carrying greater hypoglycemia and weight-gain trade-offs."
    },
    {
      "source": "drug:metformin",
      "target": "class:thiazolidinedione",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "cost_sensitive"
      ],
      "guideline_id": "guideline:nice_ng28_2026",
      "rationale": "Pioglitazone remains a lower-cost oral option when edema, heart failure, and weight trade-offs are acceptable."
    },
    {
      "source": "drug:metformin",
      "target": "class:basal_insulin",
      "type": "NEXT_LINE_IF",
      "conditions": [
        "Type 2 Diabetes",
        "severe_hyperglycemia"
      ],
      "guideline_id": "guideline:ada_2025",
      "rationale": "Basal insulin is appropriate when hyperglycemia is marked, catabolic symptoms are present, or rapid glycemic control is needed."
    },
