OPENFDA_API_KEY=
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
USE_LIVE_INGESTION=false
USE_LIVE_OPENFDA_INGESTION=false
USE_LIVE_CLINICALTRIALS_INGESTION=false
USE_LIVE_PUBMED_INGESTION=false
USE_LIVE_OPENTARGETS_INGESTION=false
USE_LIVE_CHEMBL_INGESTION=false
USE_LIVE_UNIPROT_INGESTION=false
USE_LIVE_WHO_INGESTION=false
USE_LIVE_DRUGBANK_OPEN_INGESTION=false
OPENTARGETS_GRAPHQL_URL=https://api.platform.opentargets.org/api/v4/graphql
ENSEMBL_LOOKUP_BASE_URL=https://rest.ensembl.org/lookup/symbol/homo_sapiens
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data
UNIPROT_BASE_URL=https://rest.uniprot.org/uniprotkb
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api

USE_OLLAMA_ROUTER=auto
USE_OLLAMA_SYNTHESIS=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ROUTER_MODEL=llama3.1:8b
OLLAMA_SYNTHESIS_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=15m
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ALLOW_DOWNLOAD=false
EMBEDDING_AUTO_TRY_SENTENCE_TRANSFORMERS=false
OLLAMA_EMBED_MODEL=nomic-embed-text
DRUGBANK_API_KEY=
DRUGBANK_API_BASE_URL=https://api.drugbank.com/v1/drugs

# Host-machine defaults for running `python3 main.py ...` outside Docker.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=t2d_intelligence
USE_MONGODB_BACKEND=false
SYNC_TO_MONGODB=false
MONGODB_SYNC_RETRIES=10
MONGODB_SYNC_DELAY_SECONDS=1.5

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
USE_NEO4J_BACKEND=false
SYNC_TO_NEO4J=false
NEO4J_SYNC_RETRIES=10
NEO4J_SYNC_DELAY_SECONDS=1.5

APP_LOG_LEVEL=INFO
